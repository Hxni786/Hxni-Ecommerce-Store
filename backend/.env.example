# ─────────────────────────────────────────────────────────────
#  HXNI ECOMMERCE — Backend Environment Variables
#  Copy this to .env and fill in your local values.
#  NEVER commit the real .env to version control.
# ─────────────────────────────────────────────────────────────

# MySQL connection
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=hxni_store

# Server
PORT=3001

# CORS — comma-separated list of allowed origins
# For Expo Go, this is usually exp://192.168.x.x:8081
ALLOWED_ORIGINS=http://localhost:8081,exp://localhost:8081
